{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://instruments.js/evals/listening/experiment-schema-v1.json",
  "title": "instruments.js blind-listening experiment v1",
  "type": "object",
  "required": ["schema_version", "id", "title", "purpose", "instructions", "sample_rate", "level_matching", "randomization", "exclusion_policy", "trials"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "title": { "type": "string", "minLength": 1 },
    "purpose": { "enum": ["harness_validation", "iteration", "release_gate"] },
    "instructions": { "type": "string", "minLength": 1 },
    "sample_rate": { "enum": [44100, 48000] },
    "level_matching": {
      "type": "object",
      "required": ["method", "target_lufs", "tolerance_lu"],
      "properties": {
        "method": { "enum": ["bs1770_integrated", "declared_prematched"] },
        "target_lufs": { "type": "number" },
        "tolerance_lu": { "type": "number", "minimum": 0, "maximum": 2 }
      },
      "additionalProperties": false
    },
    "randomization": {
      "type": "object",
      "required": ["algorithm", "seed_policy"],
      "properties": {
        "algorithm": { "const": "xorshift32-fisher-yates-v1" },
        "seed_policy": { "enum": ["per_listener", "fixed_pilot"] }
      },
      "additionalProperties": false
    },
    "exclusion_policy": {
      "type": "object",
      "required": ["min_completed_trials", "hidden_reference_min_score", "min_plays_per_stimulus"],
      "properties": {
        "min_completed_trials": { "type": "integer", "minimum": 1 },
        "hidden_reference_min_score": { "type": "integer", "minimum": 0, "maximum": 100 },
        "min_plays_per_stimulus": { "type": "integer", "minimum": 1, "maximum": 10 }
      },
      "additionalProperties": false
    },
    "provenance": {
      "type": "object",
      "required": ["generator", "candidate_commit", "baseline_commit", "metric_version", "case_manifest_sha256"],
      "properties": {
        "generator": { "const": "campaign-ab-v1" },
        "candidate_commit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "baseline_commit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "metric_version": { "type": "string", "minLength": 1 },
        "case_manifest_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      },
      "additionalProperties": false
    },
    "trials": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/trial" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "audio": {
      "type": "object",
      "required": ["id", "path", "sha256"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "path": { "type": "string", "pattern": "^(?!/)(?!.*\\.\\.).+\\.wav$" },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      },
      "additionalProperties": false
    },
    "stimulus": {
      "type": "object",
      "required": ["id", "path", "sha256", "role"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "path": { "type": "string", "pattern": "^(?!/)(?!.*\\.\\.).+\\.wav$" },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "role": { "enum": ["candidate", "incumbent", "hidden_reference", "anchor"] },
        "provenance": {
          "type": "object",
          "required": ["source_sha256", "gain_db", "integrated_lufs_before", "integrated_lufs_after"],
          "properties": {
            "source_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "gain_db": { "type": "number" },
            "integrated_lufs_before": { "type": "number" },
            "integrated_lufs_after": { "type": "number" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "trial": {
      "type": "object",
      "required": ["id", "protocol", "prompt", "stimuli"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "protocol": { "enum": ["ab", "abx", "mushra"] },
        "prompt": { "type": "string", "minLength": 1 },
        "reference": { "$ref": "#/$defs/audio" },
        "x_source": { "type": "string" },
        "stimuli": { "type": "array", "minItems": 2, "items": { "$ref": "#/$defs/stimulus" } }
      },
      "additionalProperties": false
    }
  }
}
