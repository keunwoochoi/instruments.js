{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://instruments.js/evals/cases/schema-v1.1.json",
  "title": "instruments.js reference campaign cases v1.1",
  "type": "object",
  "required": ["schema_version", "family", "cases"],
  "properties": {
    "schema_version": { "const": "1.1.0" },
    "family": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "description": { "type": "string" },
    "cases": {
      "type": "array",
      "minItems": 2,
      "items": { "$ref": "#/$defs/case" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "case": {
      "type": "object",
      "required": ["id", "role", "reference", "reference_contract_id", "reference_sha256", "render", "analysis"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "role": { "enum": ["tune", "held_out", "listening_only", "artifact_anchor"] },
        "reference": { "type": "string", "minLength": 1 },
        "reference_contract_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.-]*$" },
        "reference_sha256": { "oneOf": [{ "$ref": "#/$defs/sha256" }, { "type": "null" }] },
        "render": {
          "type": "object",
          "required": ["family", "midi", "velocity", "note_seconds", "total_seconds", "sample_rate", "lead_seconds"],
          "properties": {
            "family": { "type": "string" },
            "midi": { "type": "integer", "minimum": 0, "maximum": 127 },
            "velocity": { "type": "integer", "minimum": 1, "maximum": 127 },
            "note_seconds": { "type": "number", "exclusiveMinimum": 0 },
            "total_seconds": { "type": "number", "exclusiveMinimum": 0 },
            "sample_rate": { "enum": [44100, 48000] },
            "lead_seconds": { "type": "number", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "analysis": {
          "type": "object",
          "required": ["profile", "required_axes"],
          "properties": {
            "profile": { "enum": ["default", "pitched", "kick", "cymbal"] },
            "required_axes": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
            "max_post_note_off_db": { "type": "number" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  }
}
